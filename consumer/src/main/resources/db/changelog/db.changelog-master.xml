<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-waybill-schema" author="waybill" runAlways="true">
        <sqlFile path="sql/001-create-waybill-schema.sql" relativeToChangelogFile="true"/>
    </changeSet>

    <changeSet id="002-create-xslt-template-table" author="waybill" runAlways="true">
        <sqlFile path="sql/002-create-xslt-template-table.sql" relativeToChangelogFile="true"/>
    </changeSet>

    <changeSet id="003-insert-default-xslt-templates" author="waybill" runAlways="true">
        <sqlFile path="sql/003-insert-default-xslt-templates.sql" relativeToChangelogFile="true" splitStatements="false"/>
    </changeSet>
</databaseChangeLog>
